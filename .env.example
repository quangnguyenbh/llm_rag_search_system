# Environment
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://rag_user:rag_password@localhost:5432/rag_search

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant (Cloud — set URL+KEY for cloud, or HOST+PORT for local)
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=manual_chunks

# Embedding (AWS Bedrock)
EMBEDDING_PROVIDER=bedrock
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=256
AWS_BEDROCK_REGION=ap-southeast-1

# Object Storage (S3/GCS)
STORAGE_BACKEND=local
STORAGE_BUCKET=rag-search-documents
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Crawler
CRAWLER_DATA_DIR=./data/raw
CRAWLER_RATE_LIMIT_SECONDS=2
